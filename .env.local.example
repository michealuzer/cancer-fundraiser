NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Needed for webhook inserts (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SITE_URL=https://smallfighters.netlify.app

# PayPal — get these from https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# Sandbox: https://api-m.sandbox.paypal.com  |  Live: https://api-m.paypal.com
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
